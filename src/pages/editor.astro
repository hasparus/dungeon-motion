---
import { DungeonEditor } from '../text-editor';
import '../index.css';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#EFF4F2" />
    <title>editor — dungeon motion</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href="/fonts/Avara-Black.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Avara-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Avara-BoldItalic.woff2" as="font" type="font/woff2" crossorigin />
    <link href="/fonts.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:wght@400;600;700&display=block" rel="stylesheet">
  </head>
  <body class="m-0">
    <DungeonEditor client:only="react">
      <main class="min-h-screen">
        <div class="mx-auto max-w-3xl px-4 py-24 md:px-6 animate-pulse">
          <div class="h-8 w-2/3 rounded bg-stone-200 dark:bg-stone-800 mb-4"></div>
          <div class="h-4 w-full rounded bg-stone-200 dark:bg-stone-800 mb-3"></div>
          <div class="h-4 w-5/6 rounded bg-stone-200 dark:bg-stone-800 mb-6"></div>
          <div class="h-6 w-1/2 rounded bg-stone-200 dark:bg-stone-800 mb-3"></div>
          <div class="h-4 w-full rounded bg-stone-200 dark:bg-stone-800 mb-3"></div>
          <div class="h-4 w-4/5 rounded bg-stone-200 dark:bg-stone-800"></div>
        </div>
      </main>
    </DungeonEditor>
  </body>
</html>

<style>
  @media print {
    @page {
      size: A4 portrait;
      margin: 12mm;
    }
  }
</style>
